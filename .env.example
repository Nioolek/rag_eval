# ===========================================
# LLM Configuration
# ===========================================
# Required: OpenAI API Key for LLM-based evaluation
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom OpenAI API base URL (for Azure, etc.)
OPENAI_API_BASE=https://api.openai.com/v1

# Model to use for evaluation
OPENAI_MODEL=gpt-4

# Max tokens for LLM responses
OPENAI_MAX_TOKENS=4096

# Temperature for LLM responses (0.0 = deterministic)
OPENAI_TEMPERATURE=0.0

# Timeout for LLM API calls (seconds)
OPENAI_TIMEOUT=120

# ===========================================
# RAG Service Configuration
# ===========================================
# URL of your RAG service (LangGraph RemoteGraph)
RAG_SERVICE_URL=http://localhost:8000

# Timeout for RAG service calls (seconds)
RAG_TIMEOUT=60

# Maximum retries for RAG service calls
RAG_MAX_RETRIES=3

# Delay between retries (seconds)
RAG_RETRY_DELAY=1.0

# ===========================================
# Storage Configuration
# ===========================================
# Storage type: "local" or "sqlite"
STORAGE_TYPE=local

# Data directory for local storage
DATA_DIR=./data

# SQLite database URL (if using sqlite storage)
# DATABASE_URL=sqlite:///./data/rag_eval.db

# Chunk size for file operations
FILE_CHUNK_SIZE=8192

# ===========================================
# UI Configuration (Gradio)
# ===========================================
# Server host address
GRADIO_SERVER_NAME=0.0.0.0

# Server port
GRADIO_SERVER_PORT=7860

# Create public share link
GRADIO_SHARE=false

# Maximum threads for Gradio
GRADIO_MAX_THREADS=40

# ===========================================
# Evaluation Configuration
# ===========================================
# Maximum concurrent evaluations
MAX_CONCURRENT_EVALUATIONS=10

# Evaluation timeout (seconds)
EVALUATION_TIMEOUT=120

# Enable LLM-based evaluation
ENABLE_LLM_EVALUATION=true